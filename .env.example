# Base de datos (Supabase PostgreSQL con pooler)
DATABASE_URL="postgresql://postgres:password@host:6543/postgres?pgbouncer=true&sslmode=require"

# Autenticación
AUTH_SECRET="generate-a-random-secret"

# URL pública (para enlaces en emails, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase Storage (para imágenes de productos)
NEXT_PUBLIC_SUPABASE_URL="https://bhrcgjoxlaczltshijtr.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_KT32cWk8E8zSnV3GaCHV4w_HIEKD2nd"

# Supabase Service Role (para operaciones de storage del lado del servidor)
# Obtén la clave en Supabase Dashboard > Settings > API > service_role key
# IMPORTANTE: NUNCA exponer esta clave en el frontend
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIs..."

# WhatsApp Cloud API (notificaciones automáticas de pedidos)
# Crear app en https://developers.facebook.com → WhatsApp → Get Started
# Obtener Phone Number ID y generar token permanente en Dashboard
# WHATSAPP_PHONE_NUMBER_ID="your_phone_number_id"
# WHATSAPP_ACCESS_TOKEN="your_permanent_access_token"
# WHATSAPP_API_VERSION="v22.0"

# ePayco (pasarela de pagos colombiana)
# Registrarse en https://epayco.co y obtener credenciales en Módulo Administrativo > Integraciones
EPAYCO_PUBLIC_KEY="your_public_key"
EPAYCO_PRIVATE_KEY="your_private_key"
EPAYCO_CUSTOMER_ID="your_customer_id"
EPAYCO_TEST="true"  # "true" para pruebas, "false" para producción

# Sentry (monitoreo de errores y rendimiento)
# Crear proyecto en https://sentry.io y copiar el DSN
SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"
SENTRY_ORG="container-store"
SENTRY_PROJECT="nextjs"
